{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "format": "npm run prettier:fix",
    "clean:api": "node --eval \"import { rmSync } from 'node:fs'; rmSync('./src/api-access/generated', { recursive: true, force: true });\"",
    "gen:api": "orval --config ./orval.config.ts && npm run format",
    "gen:api:clean": "npm run clean:api && npm run gen:api",
    "pre:push": "run-s lint format build test"
  },
  "dependencies": {
    "@bcgov/design-tokens": "^5.0.0",
    "@date-io/luxon": "^3.2.0",
    "@fullcalendar/core": "^7.0.1",
    "@fullcalendar/vue3": "^7.0.1",
    "@vueuse/core": "^14.3.0",
    "luxon": "^3.7.2",
    "pinia": "^4.0.2",
    "temporal-polyfill": "^1.0.1",
    "vue": "^3.5.40",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.2.0",
    "vuetify": "^4.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@mdi/js": "^7.4.47",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/eslint-plugin": "^1.6.23",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.74.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-vue": "^10.10.0",
    "happy-dom": "^20.11.0",
    "jiti": "^2.6.1",
    "msw": "^2.15.0",
    "npm-run-all2": "^9.0.1",
    "orval": "^8.22.0",
    "oxlint": "^1.74.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
