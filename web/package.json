{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "format": "npm run prettier:fix",
    "clean:api": "node --eval \"import { rmSync } from 'node:fs'; rmSync('./src/api-access/generated', { recursive: true, force: true });\"",
    "gen:api": "orval --config ./orval.config.ts && npm run format",
    "gen:api:clean": "npm run clean:api && npm run gen:api",
    "pre:push": "run-s lint format build test"
  },
  "dependencies": {
    "@bcgov/design-tokens": "^5.0.0",
    "@date-io/luxon": "^3.2.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@vueuse/core": "^14.3.0",
    "luxon": "^3.7.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.7",
    "vuetify": "^4.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@mdi/js": "^7.4.47",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.18",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.68.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.8.3",
    "jiti": "^2.6.1",
    "msw": "^2.15.0",
    "npm-run-all2": "^9.0.1",
    "orval": "^8.20.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
