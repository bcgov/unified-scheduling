{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "run-s lint:*",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "format": "npm run prettier:fix",
    "clean:api": "node --eval \"import { rmSync } from 'node:fs'; rmSync('./src/api-access/generated', { recursive: true, force: true });\"",
    "gen:api": "orval --config ./orval.config.ts && npm run format",
    "gen:api:clean": "npm run clean:api && npm run gen:api",
    "pre:push": "run-s lint format build test"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "jiti": "^2.6.1",
    "msw": "^2.12.10",
    "npm-run-all2": "^8.0.4",
    "orval": "^8.5.2",
    "oxlint": "^1.51.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vite": "8.0.0-beta.15",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "vite": "8.0.0-beta.15"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
