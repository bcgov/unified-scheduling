{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
    }
  },
  "DatabaseConnectionString": "Host=db;Port=5432;Database=unifieddb;Username=uniuser;Password=unipassword;Enlist=true;MinPoolSize=10;",
  "FeatureFlags": {
    "CalendarModule": true,
    "StatsModule": true,
    "MyTeamsModule": true,
    "UserBadgeNumber": true,
    "SchedulingModule": false,
    "TrainingModule": true
  },
  "CalendarSeedData": {
    "HolidaysFilePath": "SeedData/bc-holidays.json"
  },
  "SeedData": {
    "DataSets": [
      "platform-system-user",
      "user-management-permissions",
      "default-roles",
      "stats-permissions",
      "sheriff-region-location-data",
      "training-permissions"
    ]
  },
  "UserManagement": {
    "UploadPhotoSizeLimitKb": 400
  },
  "Application": {
    "Name": "Unified Scheduling",
    "SupportEmail": "support@example.com"
  },
  "HttpLogging": {
    "Enabled": true,
    "LogBodies": false
  }
}
