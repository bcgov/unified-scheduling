{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
    }
  },
  "DatabaseConnectionString": "Host=[DB_HOST];Port=[DB_PORT];Username=[DB_USERNAME];Password=[DB_PASSWORD];Database=[DB_NAME];",
  "FeatureFlags": {
    "CalendarModule": false,
    "SchedulingModule": false,
    "StatsModule": true,
    "TrainingModule": false,
    "MyTeamsModule": false,
    "UserBadgeNumber": false
  },
  "CookieName": {
    "UnifiedAuth": "UnifiedAuth"
  },
  "Cors": {
    "AllowedOrigins": "[CORS_ALLOWED_ORIGINS]"
  },
  "CalendarSeedData": {
    "HolidaysFilePath": "SeedData/bc-holidays.json"
  },
  "UserManagement": {
    "UploadPhotoSizeLimitKb": "[UPLOAD_PHOTO_SIZE_LIMIT_KB]"
  },
  "Application": {
    "Name": "Unified Scheduling",
    "SupportEmail": "support@example.com"
  },
  "AllowedHosts": "*",
  "HttpLogging": {
    "Enabled": false,
    "LogBodies": false
  },
  "Hangfire": {
    "Enabled": true,
    "ServerEnabled": true,
    "DashboardEnabled": true,
    "PrepareSchemaIfNecessary": false,
    "RetryCount": 3
  }
}
