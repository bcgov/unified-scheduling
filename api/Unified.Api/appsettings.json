{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DatabaseConnectionString": "Host=[DB_HOST];Port=[DB_PORT];Username=[DB_USERNAME];Password=[DB_PASSWORD];Database=[DB_NAME];",
  "FeatureFlags": {
    "SchedulingModule": false,
    "StatsModule": false,
    "MyTeamsModule": false,
    "UserBadgeNumber": false
  },
  "CookieName": {
    "UnifiedAuth": "UnifiedAuth"
  },
  "Cors": {
    "AllowedOrigins": "[CORS_ALLOWED_ORIGINS]"
  },
  "AllowedHosts": "*"
}
